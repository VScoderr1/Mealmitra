# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/mealmitra
# Or use MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/mealmitra

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Razorpay (optional - leave blank to use built-in mock payment mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (Nodemailer via Gmail SMTP - optional, app works fine without it, just logs instead)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=MealMitra <no-reply@mealmitra.com>

# AI Chatbot (optional - leave blank to use the built-in rule-based assistant)
# Supports either provider; if both are blank, the rule-based fallback is used automatically.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Admin seed account (used by npm run seed)
ADMIN_EMAIL=admin@mealmitra.com
ADMIN_PASSWORD=Admin@12345
